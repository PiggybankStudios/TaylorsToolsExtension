{
	"name": "taylors-tools",
	"displayName": "TaylorsTools",
	"description": "A collection of tools that replicate behavior I had in Sublime Text and other editors",
	"homepage": "https://github.com/PiggybankStudios/TaylorsToolsExtension",
	"repository": "https://github.com/PiggybankStudios/TaylorsToolsExtension",
	"version": "0.0.3",
	"license": "MIT",
	"author": "Taylor Robbins <robbitay@live.com> (https://www.robbitay.com/)",
	"engines": {
		"vscode": "^1.109.0"
	},
	"keywords": [
		"sublime",
		"commands",
		"cursor",
		"snippet"
	],
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"files": [
		"package.json",
		"CHANGELOG.md",
		"README.md",
		"LICENSE.txt",
		"dist/extension.js"
	],
	"contributes": {
		"commands": [
			{
				"command": "taylors-tools.test",
				"category": "Taylor",
				"title": "Test",
				"icon": "$(snake)"
			},
			{
				"command": "taylors-tools.centerScreen",
				"title": "Center Screen",
				"icon": "$(fold)"
			},
			{
				"command": "taylors-tools.gotoEmptyLine",
				"title": "Goto Empty Line (Args)",
				"icon": "$(debug-step-over)"
			},
			{
				"command": "taylors-tools.gotoNextEmptyLine",
				"title": "Goto Next Empty Line",
				"icon": "$(debug-step-over)"
			},
			{
				"command": "taylors-tools.gotoPrevEmptyLine",
				"title": "Goto Previous Empty Line",
				"icon": "$(debug-step-over)"
			},
			{
				"command": "taylors-tools.gotoNextEmptyLineExtend",
				"title": "Goto Next Empty Line (Extend Selection)",
				"icon": "$(debug-step-over)"
			},
			{
				"command": "taylors-tools.gotoPrevEmptyLineExtend",
				"title": "Goto Previous Empty Line (Extend Selection)",
				"icon": "$(debug-step-over)"
			},
			{
				"command": "taylors-tools.convertNumber",
				"title": "Convert Number (Args)",
				"icon": "$(symbol-numeric)"
			},
			{
				"command": "taylors-tools.convertHexToDec",
				"title": "Convert Hexadecimal to Decimal",
				"icon": "$(symbol-numeric)"
			},
			{
				"command": "taylors-tools.convertDecToHex",
				"title": "Convert Decimal to Hexadecimal",
				"icon": "$(symbol-numeric)"
			},
			{
				"command": "taylors-tools.convertBinToHex",
				"title": "Convert Binary to Hexadecimal",
				"icon": "$(symbol-numeric)"
			},
			{
				"command": "taylors-tools.convertHexToBin",
				"title": "Convert Hexadecimal to Binary",
				"icon": "$(symbol-numeric)"
			},
			{
				"command": "taylors-tools.convertCharsToHex",
				"title": "Convert Characters to Hexadecimal",
				"icon": "$(replace-all)"
			},
			{
				"command": "taylors-tools.convertHexToChars",
				"title": "Convert Hexadecimal to Characters",
				"icon": "$(replace-all)"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/vscode": "^1.109.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"eslint": "^9.39.3",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"webpack": "^5.105.3",
		"webpack-cli": "^6.0.1"
	}
}
